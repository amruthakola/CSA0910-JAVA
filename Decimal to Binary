import java.util.Scanner;
public class BinaryReverse {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        String bin="";

        while(n>0){
            bin=(n%2)+bin;
            n=n/2;
        }

        String rev="";
        for(int i=bin.length()-1;i>=0;i--)
            rev+=bin.charAt(i);

        int dec=Integer.parseInt(rev,2);
        System.out.println(dec);
    }
}
